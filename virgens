-- NEW: Teleport Down function with ragdoll check
local function teleportDown()
	-- Check if player is ragdoll
	if LocalPlayer.Character then
		if LocalPlayer.Character then
			-- Get the target player's character if one is selected
			local targetCharacter = nil
			local selectedPlayer = TargetEntity or lastTarget

			if selectedPlayer and selectedPlayer.Character then
				targetCharacter = selectedPlayer.Character
			end

			-- Send remote with target character if available
			if targetCharacter then
				local args = { targetCharacter }
				local success, errorMsg = pcall(function()
					game:GetService('ReplicatedStorage')
						:WaitForChild('Remotes')
						:WaitForChild('CarryService')
						:WaitForChild('RequestToCarryPlayer')
						:InvokeServer(unpack(args))
				end)

				if not success then
					warn('Failed to send carry request: ' .. tostring(errorMsg))
				else
					print('Sent carry request to: ' .. selectedPlayer.Name)
				end
			else
				print('No player selected for carry request')
			end

			-- Teleport local player
			if
				LocalPlayer.Character
				and LocalPlayer.Character:FindFirstChild('HumanoidRootPart')
			then
				local humanoidRootPart = LocalPlayer.Character.HumanoidRootPart
				local currentCFrame = humanoidRootPart.CFrame
				local newCFrame = CFrame.new(
					Vector3.new(currentCFrame.X, -490, currentCFrame.Z),
					currentCFrame.LookVector
				)

				humanoidRootPart.CFrame = newCFrame
				print(
					'Teleported to Y = -490!'
						.. (
							selectedPlayer
							and ' (Carrying: ' .. selectedPlayer.Name .. ')'
							or ''
						)
				)
			else
				warn('Character or HumanoidRootPart not found!')
			end
		else
			print("[TELEPORT] Player isn't ragdoll - cannot execute teleport")
		end
	else
		print('[TELEPORT] Ragdoll property not found - cannot execute teleport')
	end
end

-- Function to find player character in workspace.Entities
local function FindPlayerCharacter(player)
	if workspace:FindFirstChild('Entities') then
		for _, entity in ipairs(workspace.Entities:GetChildren()) do
			if entity:IsA('Model') and entity:FindFirstChild('Humanoid') then
				-- Check if this character belongs to the player by name
				if entity.Name == player.Name then
					return entity
				end
			end
		end
	end
	-- Fallback: try the default location
	return player.Character
end

local function GetRootPart(entity)
	if entity:IsA('Player') then
		entity = FindPlayerCharacter(entity)
	end
	return entity
		and (
			entity:FindFirstChild('HumanoidRootPart')
			or entity:FindFirstChild('Torso')
			or entity.PrimaryPart
		)
end

-- Function to update hitbox position (without welding)
local function UpdateHitboxPosition(player, hitbox)
	local character = FindPlayerCharacter(player)
	if not character then
		return
	end

	local rootPart = GetRootPart(character)
	if not rootPart then
		return
	end

	-- Simply update the CFrame without welding
	hitbox.CFrame = rootPart.CFrame
end

-- Function to create visible hitbox for a player
local function CreatePlayerHitbox(player)
	if playerHitboxes[player] then
		playerHitboxes[player]:Destroy()
		playerHitboxes[player] = nil
	end

	if hitboxUpdateConnections[player] then
		hitboxUpdateConnections[player]:Disconnect()
		hitboxUpdateConnections[player] = nil
	end

	local character = FindPlayerCharacter(player)
	if not character then
		return
	end

	local rootPart = GetRootPart(character)
	if not rootPart then
		return
	end

	-- Create a visible part around the player
	local hitbox = Instance.new('Part')
	hitbox.Name = 'ExtendedHitbox_' .. player.Name
	hitbox.Size = Vector3.new(8, 8, 8)
	hitbox.CFrame = rootPart.CFrame
	hitbox.Anchored = true
	hitbox.CanCollide = false
	hitbox.Transparency = 0.2
	hitbox.Material = Enum.Material.SmoothPlastic
	hitbox.BrickColor = BrickColor.new('Really blue')
	hitbox.CastShadow = false
	hitbox.Parent = workspace

	-- Adicionar contorno branco com 80% de transparência
	local outline = Instance.new('BoxHandleAdornment')
	outline.Name = 'Outline'
	outline.Adornee = hitbox
	outline.Size = hitbox.Size
	outline.Color3 = Color3.new(1, 1, 1)
	outline.Transparency = 0.8
	outline.AlwaysOnTop = true
	outline.ZIndex = 0
	outline.Parent = hitbox

	-- Adicionar nome do jogador mais clean e em branco
	local billboard = Instance.new('BillboardGui')
	billboard.Parent = hitbox
	billboard.Adornee = hitbox
	billboard.Size = UDim2.new(0, 150, 0, 30)
	billboard.StudsOffset = Vector3.new(0, 6, 0)
	billboard.AlwaysOnTop = true
	billboard.MaxDistance = 500

	local nameLabel = Instance.new('TextLabel')
	nameLabel.Parent = billboard
	nameLabel.Size = UDim2.new(1, 0, 1, 0)
	nameLabel.Text = player.Name:sub(1, 10)
	nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	nameLabel.TextScaled = false
	nameLabel.TextSize = 14
	nameLabel.BackgroundTransparency = 1
	nameLabel.Font = Enum.Font.Gotham
	nameLabel.TextStrokeTransparency = 0.7
	nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)

	-- Armazenar a hitbox
	playerHitboxes[player] = hitbox

	-- Criar conexão para atualizar a posição da hitbox a cada frame
	hitboxUpdateConnections[player] = RunService.RenderStepped:Connect(
		function()
			UpdateHitboxPosition(player, hitbox)
		end
	)
end

-- Function to show all player hitboxes
local function ShowAllPlayerHighlights()
	print('[HIGHLIGHT] Showing hitboxes for all players')
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			CreatePlayerHitbox(player)

			-- Set up connections to recreate hitboxes when character changes
			if not highlightConnections[player] then
				highlightConnections[player] = {}

				local function refreshHitbox()
					if isRDown then
						wait(0.5)
						CreatePlayerHitbox(player)
					end
				end

				local charAddedConn =
					player.CharacterAdded:Connect(refreshHitbox)
				local charRemovingConn = player.CharacterRemoving:Connect(
					function()
						if playerHitboxes[player] then
							playerHitboxes[player]:Destroy()
							playerHitboxes[player] = nil
						end
						if hitboxUpdateConnections[player] then
							hitboxUpdateConnections[player]:Disconnect()
							hitboxUpdateConnections[player] = nil
						end
					end
				)

				table.insert(highlightConnections[player], charAddedConn)
				table.insert(highlightConnections[player], charRemovingConn)
			end
		end
	end
end

-- Function to hide all player hitboxes
local function HideAllPlayerHighlights()
	print('[HIGHLIGHT] Hiding all hitboxes')
	for player, hitbox in pairs(playerHitboxes) do
		if hitbox then
			hitbox:Destroy()
			playerHitboxes[player] = nil
		end
	end

	for player, connection in pairs(hitboxUpdateConnections) do
		if connection then
			connection:Disconnect()
		end
	end
	hitboxUpdateConnections = {}

	-- Clean up connections
	for player, connections in pairs(highlightConnections) do
		for _, conn in ipairs(connections) do
			conn:Disconnect()
		end
	end
	highlightConnections = {}
end

local function GetPlayerFromMouse()
	if not mouse then
		return nil
	end

	local mousePos = Vector2.new(mouse.X, mouse.Y)
	local ray = camera:ScreenPointToRay(mousePos.X, mousePos.Y)
	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
	raycastParams.FilterDescendantsInstances = { LocalPlayer.Character }
	raycastParams.IgnoreWater = true

	local result =
		workspace:Raycast(ray.Origin, ray.Direction * 1000, raycastParams)

	if result then
		for player, hitbox in pairs(playerHitboxes) do
			if result.Instance == hitbox then
				return player
			end
		end

		local character = result.Instance:FindFirstAncestorOfClass('Model')
		if character and character:FindFirstChildOfClass('Humanoid') then
			local player = Players:GetPlayerFromCharacter(character)
			if player and player ~= LocalPlayer then
				return player
			end
		end
	end

	local closestPlayer = nil
	local closestDot = -1

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			local character = FindPlayerCharacter(player)
			if character then
				local rootPart = GetRootPart(character)
				if rootPart then
					local toPlayer = (
						rootPart.Position - camera.CFrame.Position
					).Unit
					local dot = ray.Direction:Dot(toPlayer)

					if dot > 0.95 and dot > closestDot then
						local obstacleCheck = workspace:Raycast(
							camera.CFrame.Position,
							toPlayer
								* (rootPart.Position - camera.CFrame.Position).Magnitude,
							raycastParams
						)

						if
							not obstacleCheck
							or obstacleCheck.Instance:IsDescendantOf(character)
						then
							closestPlayer = player
							closestDot = dot
						end
					end
				end
			end
		end
	end

	return closestPlayer
end

-- DEFINE UpdateCamera BEFORE any functions that use it
local function UpdateCamera()
	if not TargetEntity then
		if workspace.CurrentCamera.CameraType == Enum.CameraType.Scriptable then
			workspace.CurrentCamera.CameraType = OriginalCameraType
		end
		return
	end

	local TargetRoot = GetRootPart(TargetEntity)
	local MyRoot = GetRootPart(LocalPlayer)

	if not TargetRoot or not MyRoot then
		print(
			'[CAMERA] Missing root parts - Target:',
			TargetRoot ~= nil,
			'My:',
			MyRoot ~= nil
		)
		if workspace.CurrentCamera.CameraType == Enum.CameraType.Scriptable then
			workspace.CurrentCamera.CameraType = OriginalCameraType
		end
		return
	end

	local distance = (TargetRoot.Position - MyRoot.Position).Magnitude
	if distance <= MAX_DISTANCE then
		workspace.CurrentCamera.CameraType = Enum.CameraType.Scriptable

		local lookDirection = (TargetRoot.Position - MyRoot.Position).Unit
		local cameraOffset = lookDirection * -10 + Vector3.new(0, 3, 0)
		local cameraPos = MyRoot.Position + cameraOffset

		workspace.CurrentCamera.CFrame =
			CFrame.new(cameraPos, TargetRoot.Position)

		print(
			'[CAMERA] Locked on:',
			TargetEntity.Name,
			'Distance:',
			math.floor(distance)
		)
	else
		if workspace.CurrentCamera.CameraType == Enum.CameraType.Scriptable then
			workspace.CurrentCamera.CameraType = OriginalCameraType
		end
		print('[CAMERA] Target too far away:', distance)
	end
end

-- DEFINE StopMouseHook BEFORE StartMouseHook
local function StopMouseHook()
	if mouseHookActive and mouseMeta and originalIndex then
		setreadonly(mouseMeta, false)
		mouseMeta.__index = originalIndex
		setreadonly(mouseMeta, true)
		mouseHookActive = false
		print('[MOUSE] Hook stopped')
	end
end

-- NOW define StartMouseHook after StopMouseHook
local function StartMouseHook(targetPlayer)
	if not mouseMeta or not originalIndex then
		warn('[MOUSE] Cannot hook mouse - metatable access not available')
		return
	end
	if mouseHookActive then
		StopMouseHook()
	end
	setreadonly(mouseMeta, false)
	mouseMeta.__index = newcclosure(function(self, key)
		if isRDown then
			return originalIndex(self, key)
		end

		if key == 'X' then
			local character = FindPlayerCharacter(targetPlayer)
			if character and character:FindFirstChild('HumanoidRootPart') then
				local screenPoint = camera:WorldToScreenPoint(
					character.HumanoidRootPart.Position
				)
				return screenPoint.X
			end
			return originalX
		elseif key == 'Y' then
			local character = FindPlayerCharacter(targetPlayer)
			if character and character:FindFirstChild('HumanoidRootPart') then
				local screenPoint = camera:WorldToScreenPoint(
					character.HumanoidRootPart.Position
				)
				return screenPoint.Y
			end
			return originalY
		elseif key == 'Hit' then
			local character = FindPlayerCharacter(targetPlayer)
			if character and character:FindFirstChild('HumanoidRootPart') then
				return CFrame.new(character.HumanoidRootPart.Position)
			end
			return originalIndex(self, key)
		elseif key == 'Target' then
			local character = FindPlayerCharacter(targetPlayer)
			if character and character:FindFirstChild('HumanoidRootPart') then
				return character.HumanoidRootPart
			end
			return originalIndex(self, key)
		end
		return originalIndex(self, key)
	end)
	setreadonly(mouseMeta, true)
	mouseHookActive = true
	print('[MOUSE] Hook started for:', targetPlayer.Name)
end

local function UpdateMouseHook()
	if mouseHookActive and TargetEntity then
		StopMouseHook()
		StartMouseHook(TargetEntity)
	end
end

local function SetTarget(newTarget)
	if newTarget then
		print('[SYSTEM] Setting new target:', newTarget.Name)
		TargetEntity = newTarget
		StartMouseHook(newTarget)

		UpdateCamera()

		if connection then
			connection:Disconnect()
		end
		connection = RunService.RenderStepped:Connect(UpdateCamera)

		print('[SYSTEM] Target set and camera locked:', newTarget.Name)
	else
		print('[SYSTEM] Removing target')
		TargetEntity = nil
		StopMouseHook()

		if connection then
			connection:Disconnect()
			connection = nil
		end

		if workspace.CurrentCamera.CameraType == Enum.CameraType.Scriptable then
			workspace.CurrentCamera.CameraType = OriginalCameraType
		end

		print('[SYSTEM] Target removed and camera unlocked')
	end
end

