local targetClicksPerSecond = 130
local clickInterval = 1 / targetClicksPerSecond
local accumulatedTime = 0

local spamConnection = RunService.Heartbeat:Connect(function(deltaTime)
	if isFDown and TargetEntity then
		local myRoot = GetRootPart(LocalPlayer)
		local targetRoot = GetRootPart(TargetEntity)
		if myRoot and targetRoot then
			local distance = (myRoot.Position - targetRoot.Position).Magnitude
			if distance <= 70 then
				accumulatedTime = accumulatedTime + deltaTime
				while accumulatedTime >= clickInterval do
					local targetCharacter = FindPlayerCharacter(TargetEntity)
					if targetCharacter then
						local args2 = { targetCharacter }
						abilityRemote:FireServer(unpack(args2))
					end
					accumulatedTime = accumulatedTime - clickInterval
				end
			end
		end
	end
end)

