-- [[ KERNEL V190 - NETWORK BALANCED ]] --

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local Stats = game:GetService("Stats")
local LocalPlayer = Players.LocalPlayer
local StarterGui = game:GetService("StarterGui")

local function Notify(title, text)
    pcall(function()
        StarterGui:SetCore("SendNotification", {Title = title, Text = text, Duration = 2})
    end)
end

local Begin, Activate = ReplicatedStorage:FindFirstChild("BeginAbility", true), ReplicatedStorage:FindFirstChild("AbilityActivated____", true)

local SETTINGS = {
    Enabled = false,
    DetectionRange = 140, 
    CombatRange = 80,     
    Backtrack = 0.9,      
    
    -- CONTROLE DE FLUXO (O segredo para o ping não subir)
    MaxPackets = 20,      -- Reduzido para não entupir a rede
    AttackDelay = 0.025,  -- Delay de segurança (Equilíbrio perfeito)
    
    ToggleKey = Enum.KeyCode.R,
    FriendsOnly = true
}

local currentTarget = nil

-- [[ 1. SILENT AIM (Otimizado) ]]
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if SETTINGS.Enabled and not checkcaller() and self == Activate and method == "FireServer" then
        if currentTarget and currentTarget:FindFirstChild("HumanoidRootPart") then
            local tHRP = currentTarget.HumanoidRootPart
            for i, v in ipairs(args) do
                if typeof(v) == "CFrame" then args[i] = tHRP.CFrame 
                elseif typeof(v) == "Vector3" then args[i] = tHRP.Position
                elseif typeof(v) == "Instance" and v:IsA("Model") then args[i] = currentTarget end
            end
        end
        if type(args[1]) == "number" and args[1] > 10^9 then args[1] = args[1] - SETTINGS.Backtrack end
        return oldNamecall(self, unpack(args))
    end
    return oldNamecall(self, ...)
end)

-- [[ 2. LOOP DE ATAQUE COM CONTROLE DE PING ]]
task.spawn(function()
    while true do
        local delta = task.wait(SETTINGS.AttackDelay)
        
        if SETTINGS.Enabled and currentTarget then
            local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local tHRP = currentTarget:FindFirstChild("HumanoidRootPart")
            
            if hrp and tHRP then
                if (hrp.Position - tHRP.Position).Magnitude <= SETTINGS.CombatRange then
                    -- Monitor de Ping em tempo real
                    local currentPing = Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
                    
                    -- Se o ping subir demais, o script "pensa" e espera a rede limpar
                    if currentPing < 600 then 
                        if Begin then Begin:FireServer() end
                        
                        -- Envio Direto (Sem task.spawn excessivo para não criar filas)
                        for i = 1, SETTINGS.MaxPackets do
                            Activate:FireServer(currentTarget)
                        end
                    end
                end
            end
        end
    end
end)

-- [[ 3. AUTO-RECOVERY & TARGETING ]]
RunService.Heartbeat:Connect(function()
    if not SETTINGS.Enabled then return end
    
    local char = LocalPlayer.Character
    if char then
        char:SetAttribute("Stunned", false)
        char:SetAttribute("Busy", false)
        local hum = char:FindFirstChild("Humanoid")
        if hum then 
            hum.PlatformStand = false
            if hum:GetState() == Enum.HumanoidStateType.Ragdoll then hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
        end
    end

    -- Busca Alvo
    local target, bestDist = nil, SETTINGS.DetectionRange
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local trp = p.Character:FindFirstChild("HumanoidRootPart")
            if trp and p.Character.Humanoid.Health > 0 then
                local isFriend = false
                if SETTINGS.FriendsOnly then pcall(function() isFriend = LocalPlayer:IsFriendsWith(p.UserId) end) end
                
                if not isFriend then
                    local d = (trp.Position - char.HumanoidRootPart.Position).Magnitude
                    if d < bestDist then target = p.Character bestDist = d end
                end
            end
        end
    end
    currentTarget = target
end)

-- [[ TOGGLE ]]
UserInputService.InputBegan:Connect(function(i, g)
    if g then return end
    if i.KeyCode == SETTINGS.ToggleKey then
        SETTINGS.Enabled = not SETTINGS.Enabled
        Notify("kernel xereca 193", SETTINGS.Enabled and "ESTÁVEL: LIGADO" or "ESTÁVEL: DESLIGADO")
        if not SETTINGS.Enabled then currentTarget = nil end
    end
end)
